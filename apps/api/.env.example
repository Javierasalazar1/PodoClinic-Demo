DATABASE_URL=postgresql://user:password@localhost:5432/podoclinic

# JWT
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# AES-256 key (exactly 32 bytes hex)
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

FRONTEND_URL=http://localhost:5173
NODE_ENV=development
PORT=3001

# Test credentials (used only in integration tests, never in production)
TEST_ADMIN_EMAIL=admin@podoclinic-demo.cl
TEST_ADMIN_PASSWORD=Admin1234!
