# PodoClinic — .gitignore

# Dependencies
node_modules/

# Build outputs
dist/
build/
.turbo/

# Environment files (never commit real credentials!)
.env
.env.local
.env.*.local
# .env.demo y .env.example son seguros (sin credenciales reales) — NO se excluyen
apps/api/.env
apps/web/.env

# Logs
*.log
npm-debug.log*
apps/api/logs/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Prisma
apps/api/prisma/migrations/*.sql

# TypeScript
*.tsbuildinfo
