npm-debug.log*
apps/api/logs/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Prisma
apps/api/prisma/migrations/*.sql

# TypeScript
*.tsbuildinfo
